# .env.example - This file is committed to Git as documentation
# Copy this to .env and fill in your actual values

# Core Configuration
PYTHONPATH=src

# ArcGIS Online Configuration (Required)
AGOL_PORTAL_URL=https://your-org.maps.arcgis.com

# Authentication method: credentials | oauth
#   credentials - Username/password login (no 2FA)
#   oauth       - Browser-based OAuth 2.0 login (supports 2FA, requires AGOL_CLIENT_ID)
AGOL_AUTH_METHOD=credentials

# Method: credentials
AGOL_USERNAME=your_username
AGOL_PASSWORD=your_secure_password_here

# Method: oauth (browser login with 2FA)
# AGOL_AUTH_METHOD=oauth
# AGOL_CLIENT_ID=your_client_id_here     # From AGOL app registration (Developer Credentials)
# AGOL_CLIENT_SECRET=your_secret_here    # Optional: enables server-to-server auth (no browser, no 2FA)
# AGOL_PROFILE=your_profile_name         # Optional: cache session to skip re-login on repeat runs
# AGOL_CONTENT_OWNER=your_username       # Recommended for app auth; restricts publish/discovery to this owner

# ArcGIS Online Advanced Settings (Optional)
# AGOL_TOKEN_EXPIRATION=9999  # Extended timeout for large datasets
# AGOL_LARGE_DATASET_THRESHOLD=10000  # Feature count threshold

# Overture Maps Configuration
OVERTURE_S3_REGION=us-west-2
OVERTURE_RELEASE=2025-08-20.0  
# OVERTURE_BASE_URL=s3://overturemaps-us-west-2/release  # Default S3 bucket

# Processing Configuration
DUCKDB_MEMORY_LIMIT=16GB
DUCKDB_THREADS=8
# DUCKDB_TEMP_DIR=/path/to/temp  # Optional: Custom temp directory

# Temp File Management (Optional)
# TEMP_RETENTION_HOURS=24  # Hours before cleanup
# TEMP_SIZE_WARNING_GB=10  # Warning threshold
# TEMP_SIZE_LIMIT_GB=20    # Hard limit

# Local Dump Configuration (Optional)
# OVERTURE_DUMP_PATH=./overturedump  # Where to store local dumps
# DUMP_MAX_MEMORY=32        # GB of RAM for dump operations
# DUMP_ENABLE_SPATIAL_INDEX=true
# DUMP_COMPRESSION=zstd     # Compression type
# DUMP_PARTITIONING=hive    # Partitioning scheme


# Batch Processing Configuration     
# BatchThreshold=200000    # Switch to batching above this many records
# BatchSize=100000         # Starting batch size
# BatchMin=50000           # Minimum batch size floor
# AppendTimeout=10800      # 3 hours timeout for append jobs       
# USE_ASYNC_APPEND=false  # Set to true to use async append or use --async argument
